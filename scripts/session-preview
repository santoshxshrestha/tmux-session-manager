#!/usr/bin/env bash

session="${1:-$(tmux display-message -p '#{session_name}')}"

tmux list-windows -t "$session" \
    -F '#{?window_active,▶,  }|#{window_index}|#{window_name}|#{pane_current_command}|#{s|/home/santosh|~|:pane_current_path}|#{window_id}' |
    awk -F'|' '{
      printf "%s  %-2s  %-12s %-12s %-20s %s\n",
             $1, $2, $3, $4, $5, $6
    }'
